# Keygen CE + dashboard environment — copy to .env and fill in.
# NEVER commit the real .env (contains encryption/signing secrets).
#
# Every value below is a placeholder — generate real ones per README.md's
# "First-time setup" (openssl rand -hex ..., uuidgen). Do not reuse these
# literal strings for anything real.

# ── Edition / mode (fixed for self-hosted CE) ──
KEYGEN_EDITION=CE
KEYGEN_MODE=singleplayer

# ── Identity ──
# KEYGEN_ACCOUNT_ID must be decided BEFORE first boot (uuidgen) — the setup
# service can't prompt interactively. See README.md.
KEYGEN_HOST=license.example.com
KEYGEN_ACCOUNT_ID=
# Only needed for the one boot where setup actually runs; remove afterward.
KEYGEN_ADMIN_EMAIL=
KEYGEN_ADMIN_PASSWORD=

# ── Secrets (openssl rand -hex 64 / 32 / 32 / 32) ──
SECRET_KEY_BASE=
ENCRYPTION_DETERMINISTIC_KEY=
ENCRYPTION_PRIMARY_KEY=
ENCRYPTION_KEY_DERIVATION_SALT=

# ── Database (dedicated Postgres in this stack) ──
KEYGEN_DB_USER=keygen
KEYGEN_DB_PASSWORD=
KEYGEN_DB_NAME=keygen

# ── Artifact storage (EXTERNAL S3-compatible server) ──
# The storage server (and its bucket) is managed separately from this
# stack. AWS_* names match what Keygen reads; set them to the external
# server's public endpoint and credentials.
# AWS_ENDPOINT is the PUBLIC presigned-URL host — licensed clients download
# updates and the dashboard uploads artifacts directly from/to it.
AWS_ENDPOINT=https://storage.example.com
# URL-safe values only (no @ : / etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=license-artifacts
AWS_REGION=us-east-1
